# Optional - Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional - Vector Database Configuration
FAISS_PERSIST_DIR=./data/faiss_db

# Optional - Text Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Optional - Embedding Model Configuration
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Optional - File Types to Index (comma-separated, include the dot)
INDEX_FILE_TYPES=.md,.txt,.py,.cs,.js,.ts,.tsx,.json,.yaml,.yml

# Optional - AI Response Length (max tokens in AI responses)
# Default: 4096. Increase if responses are being cut off.
MAX_TOKENS=4096

# Legacy - Not currently used but kept for reference
MAX_CHUNKS_PER_FILE=50
